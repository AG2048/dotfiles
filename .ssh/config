# ~/.ssh/config - SSH client configuration file
# SSH configuration for various hosts and services

# Global SSH settings
Host *
    # Use SSH protocol version 2
    Protocol 2
    
    # Enable compression
    Compression yes
    
    # Keep connections alive
    ServerAliveInterval 60
    ServerAliveCountMax 3
    
    # Connection timeout
    ConnectTimeout 10
    
    # Reuse connections
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600
    
    # Security settings
    HashKnownHosts yes
    StrictHostKeyChecking ask
    VerifyHostKeyDNS yes
    
    # Preferred authentication methods
    PreferredAuthentications publickey,keyboard-interactive,password
    
    # Use SSH agent
    AddKeysToAgent yes
    
    # Disable X11 forwarding by default
    ForwardX11 no

# GitHub configuration
Host github.com
    HostName github.com
    User git
    Port 22
    # Uncomment and set your GitHub SSH key
    # IdentityFile ~/.ssh/id_ed25519_github
    IdentitiesOnly yes
    
# GitLab configuration
Host gitlab.com
    HostName gitlab.com
    User git
    Port 22
    # Uncomment and set your GitLab SSH key
    # IdentityFile ~/.ssh/id_ed25519_gitlab
    IdentitiesOnly yes

# Bitbucket configuration
Host bitbucket.org
    HostName bitbucket.org
    User git
    Port 22
    # Uncomment and set your Bitbucket SSH key
    # IdentityFile ~/.ssh/id_ed25519_bitbucket
    IdentitiesOnly yes

