# ~/.gitconfig - Git global configuration file
# Personal git settings and aliases

[user]
    # Replace with your actual name and email
    name = Your Name
    email = your.email@example.com

[core]
    # Use global gitignore file
    excludesfile = ~/.gitignore_global
    
    # Default editor for commit messages
    editor = vim
    
    # Autocrlf settings for cross-platform compatibility
    autocrlf = input
    
    # File permissions
    filemode = true
    
    # Use pager for output
    pager = less -R

[init]
    # Default branch name for new repositories
    defaultBranch = main

[push]
    # Push only the current branch
    default = simple
    
    # Automatically set up tracking
    autoSetupRemote = true

[pull]
    # Use rebase by default when pulling
    rebase = true

[merge]
    # Include common ancestor in conflict markers
    conflictstyle = diff3
    
    # Default merge tool
    tool = vimdiff

[diff]
    # Use better diff algorithm
    algorithm = patience
    
    # Show renames and copies
    renames = copies

[color]
    # Enable color output
    ui = auto
    
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = yellow
    changed = green
    untracked = cyan

[alias]
    # Status
    st = status
    s = status --short
    
    # Add
    a = add
    aa = add --all
    
    # Commit
    c = commit
    cm = commit -m
    ca = commit --amend
    can = commit --amend --no-edit
    
    # Checkout
    co = checkout
    cob = checkout -b
    com = checkout main
    cod = checkout develop
    
    # Branch
    b = branch
    ba = branch -a
    bd = branch -d
    bD = branch -D
    
    # Log
    l = log --oneline
    lg = log --oneline --graph --decorate
    lga = log --oneline --graph --decorate --all
    ll = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    
    # Diff
    d = diff
    dc = diff --cached
    ds = diff --stat
    
    # Remote
    r = remote
    rv = remote -v
    
    # Push/Pull
    p = push
    pf = push --force-with-lease
    pl = pull
    
    # Merge
    m = merge
    mnf = merge --no-ff
    
    # Rebase
    rb = rebase
    rbi = rebase -i
    rbc = rebase --continue
    rba = rebase --abort
    
    # Reset
    unstage = reset HEAD --
    undo = reset --soft HEAD^
    hard-reset = reset --hard HEAD^
    
    # Stash
    st = stash
    stp = stash pop
    stl = stash list
    
    # Show
    last = show --stat
    
    # Misc
    contributors = shortlog -sn
    ignore = "!gi() { curl -sL https://www.toptal.com/developers/gitignore/api/$@ ;}; gi"
    
    # Find files and commits
    find = "!git ls-files | grep -i"
    grep = grep -Ii
    
    # Assume/unassume (for temporarily ignoring changes to tracked files)
    assume = update-index --assume-unchanged
    unassume = update-index --no-assume-unchanged
    assumed = "!git ls-files -v | grep ^h | cut -c 3-"

[help]
    # Automatically correct and execute mistyped commands
    autocorrect = 1

[rerere]
    # Remember how merge conflicts were resolved
    enabled = true

[fetch]
    # Automatically prune deleted remote branches
    prune = true

[rebase]
    # Use --autosquash by default
    autosquash = true
    
    # Use --autostash by default
    autostash = true

[tag]
    # Sort tags by version
    sort = version:refname

[branch]
    # Show most recently changed branches first
    sort = -committerdate

# Include local gitconfig if it exists
[include]
    path = ~/.gitconfig.local